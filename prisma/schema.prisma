// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Post {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  content     String   @db.LongText
  category    String
  tags        String   // JSON array as string
  readTime    String
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("posts")
}

model Moment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@map("moments")
}

model About {
  id       String @id @default("about")
  name     String @default("Shion")
  title    String @default("测试开发工程师")
  bio      String @db.Text
  location String @default("中国")
  github   String @default("https://github.com/JhinInn")
  tags     String @default("[\"Python\", \"Java\", \"自动化测试\", \"Next.js\"]")
  avatar   String @default("https://api.dicebear.com/7.x/avataaars/svg?seed=shion")

  @@map("about")
}
